{
  "name": "lm15",
  "version": "0.0.1",
  "description": "One interface for OpenAI, Anthropic, and Gemini. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "ai",
    "universal"
  ],
  "author": "lm15-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lm15-dev/lm15-ts.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  }
}
